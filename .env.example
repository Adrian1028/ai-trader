# ═══════════════════════════════════════════════════════════════════
# AI Trading System — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# ── Trading 212 ──────────────────────────────────────────────────
T212_ENV=demo                    # "demo" or "live"
T212_API_KEY=your_trading212_api_key_here
T212_API_SECRET=your_trading212_api_secret_here

# ── Data Providers ───────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
POLYGON_KEY=your_polygon_key_here
FINNHUB_KEY=your_finnhub_key_here
INTRINIO_KEY=

# ── Gemini AI (LLM Strategy Agent) ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram Notifications (Optional) ───────────────────────────
# Get bot token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Bot Configuration ───────────────────────────────────────────
BOT_ID=AlphaBot_01
INITIAL_CAPITAL=10000.0
LOG_LEVEL=INFO

# ── Target Stocks (Optional — defaults to 20 US stocks) ─────────
# Comma-separated ISINs to override default target list
# TARGET_ISINS=US0378331005,US5949181045,US67066G1040
